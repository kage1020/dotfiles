{
  // Editor Settings
  "diffEditor.ignoreTrimWhitespace": false,

  "editor.accessibilitySupport": "off",
  "editor.copyWithSyntaxHighlighting": false,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.fontFamily": "Source Han Code JP N",
  "editor.fontSize": 14,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.linkedEditing": true,
  "editor.minimap.renderCharacters": false,
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "editor.renderWhitespace": "boundary",
  "editor.renderLineHighlight": "all",
  "editor.unicodeHighlight.allowedCharacters": {
    "．": true,
    "，": true,
    "　": true,
    "：": true,
    "／": true,
    "？": true,
    "＊": true,
    "｜": true,
    "＜": true,
    "＞": true,
    "＂": true,
    "＇": true,
    "＆": true,
    "＃": true,
    "％": true,
    "＠": true,
    "！": true,
    "＼": true,
    "＾": true,
    "｀": true,
    "～": true
  },
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 200,

  "emmet.excludeLanguages": [],

  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
    "*.sqlite": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },

  "files.associations": {
    "*.dbclient-js": "javascript",
    "*.css": "tailwindcss"
  },
  "files.autoGuessEncoding": true,
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true,
    "**/.ruff_cache": true,
    "**/*-env.d.ts": true
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,

  "search.followSymlinks": false,

  "security.workspace.trust.untrustedFiles": "open",

  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.hideOnLastClosed": false,
  "terminal.integrated.smoothScrolling": true,

  "workbench.colorCustomizations": {
    "editor.lineHighlightBackground": "#404040A0",
    "editorStickyScroll.background": "#404040A0",
    "editorStickyScrollHover.background": "#505050A0",
    "editorLineNumber.foreground": "#606060A0"
  },
  "workbench.editor.customLabels.patterns": {
    "**/{index,main,page,layout,template,route,error,loading,default}.{js,jsx,ts,tsx}": "${dirname(0)}/${filename}.${extname}"
  },
  "workbench.editor.empty.hint": "hidden",
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "{hexdiff}:/**/*.*": "hexEditor.hexedit",
    "*.ipynb": "jupyter-notebook",
    "*.pdf": "pdf.preview"
  },
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",

  // Language Settings
  "[css]": {
    "editor.tabSize": 2
  },
  "[html]": {
    "editor.tabSize": 2
  },
  "[java]": {
    "editor.tabSize": 4
  },
  "[javascript]": {
    "editor.tabSize": 2
  },
  "js/ts.locale": "en",
  "js/ts.preferences.importModuleSpecifier": "non-relative",
  "js/ts.preferences.quoteStyle": "double",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "[javascriptreact]": {
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://developer.microsoft.com/json-schemas/": true,
    "https://biomejs.dev": true
  },
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonl]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.tabSize": 2
  },
  "markdown.editor.filePaste.enabled": "always",
  "markdown.editor.filePaste.videoSnippet": "<video controls autoplay loop muted playsinline src=\"${src}\" title=\"${title}\"></video>",
  "[mdx]": {
    "editor.tabSize": 2
  },
  "[python]": {
    "editor.tabSize": 4
  },
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "[typescript]": {
    "editor.tabSize": 2
  },
  "[typescriptreact]": {
    "editor.tabSize": 2
  },

  // Extension Settings
  "biome.suggestInstallingGlobally": false,

  "color-highlight.languages": ["*", "!python"],
  "color-highlight.markerType": "dot-before",

  "cSpell.enabledFileTypes": {
    "*": true,
    "log": false,
    "txt": false
  },
  "cSpell.userWords": [
    "autoplay",
    "gaql",
    "kage",
    "marp",
    "mathbf",
    "mathjax",
    "nuqs",
    "oklch",
    "rgba",
    "vitest"
  ],

  "database-client.autoSync": true,

  "eslint.enable": false,

  "git.autofetch": "all",
  "git.autorefresh": true,
  "git.autoStash": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",

  "github.copilot.enable": {
    "*": true,
    "scminput": false
  },
  "github.copilot.chat.codesearch.enabled": true,

  "jupyter.askForKernelRestart": false,
  "jupyter.runStartupCommands": [
    "%load_ext autoreload",
    "%autoreload 2",
    "%matplotlib inline"
  ],

  "markdown.marp.exportType": "html",
  "markdown.marp.html": "all",
  "markdown.marp.pptx.editable": "on",
  "markdown.marp.themes": [
    "https://raw.githubcontent.com/kage1020/marp-theme/main/kage1020.css",
    "https://raw.githubcontent.com/kage1020/marp-theme/main/kage1020-academic.css",
    "https://raw.githubcontent.com/kage1020/marp-theme/main/word.css"
  ],

  "markdownlint.config": {
    "MD001": false,
    "MD012": false,
    "MD024": false,
    "MD025": false,
    "MD026": false,
    "MD029": false,
    "MD033": false,
    "MD036": false,
    "MD040": false,
    "MD041": false,
    "MD045": false,
    "MD049": false
  },

  "markdown-preview-enhanced.codeBlockTheme": "github-dark.css",
  "markdown-preview-enhanced.enableExtendedTableSyntax": true,
  "markdown-preview-enhanced.hideDefaultVSCodeMarkdownPreviewButtons": false,
  "markdown-preview-enhanced.previewTheme": "atom-light.css",

  "notebook.cellToolbarLocation": {
    "default": "left"
  },
  "notebook.insertFinalNewline": true,
  "notebook.lineNumbers": "on",
  "notebook.output.scrolling": true,
  "notebook.stickyScroll.enabled": true,
  "notebook.variablesView": true,

  "prettier.enable": false,
  "prettier.semi": false,
  "prettier.trailingComma": "all",

  "tailwindCSS.classFunctions": ["clsx", "cva", "cx", "tv", "tw", "twMerge"],

  "todohighlight.keywords": [
    {
      "text": "NOTE",
      "color": "#FFFFFF",
      "backgroundColor": "#4B99D2",
      "overviewRulerColor": "rgba(75,153,210,0.8)"
    },
    {
      "text": "TODO",
      "color": "#FFFFFF",
      "backgroundColor": "#BCC256",
      "overviewRulerColor": "rgba(188,194,86,0.8)"
    }
  ]
}
