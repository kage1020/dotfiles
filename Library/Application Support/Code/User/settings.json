{
  "window.zoomLevel": 0.8,

  "editor.accessibilitySupport": "off",
  "editor.copyWithSyntaxHighlighting": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.fontSize": 15,
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Noto Sans JP'",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.linkedEditing": true,
  "editor.minimap.renderCharacters": false,
  "editor.quickSuggestions": {
    "other": "on",
    "comments": "off",
    "strings": "on"
  },
  "editor.renderWhitespace": "boundary",
  "editor.renderLineHighlight": "all",
  "editor.unicodeHighlight.allowedCharacters": {
    "：": true,
    "！": true,
    "．": true,
    "，": true
  },
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 200,

  "workbench.colorCustomizations": {
    "editor.lineHighlightBackground": "#404040A0",
    "editorStickyScroll.background": "#404040A0",
    "editorStickyScrollHover.background": "#505050A0",
    "editorLineNumber.foreground": "#606060A0"
  },
  "workbench.editor.customLabels.patterns": {
    "**/{index,main,page,layout,template,route,error,loading,default}.{js,jsx,ts,tsx}}": "${dirname(0)}/${filename}.${extname}"
  },
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook",
    "*.pdf": "latex-workshop-pdf-hook",
    "*.assets": "default"
  },
  "workbench.startupEditor": "none",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.colorTheme": "Default Dark+",

  "security.workspace.trust.untrustedFiles": "open",
  "security.allowedUNCHosts": [ "wsl.localhost" ],

  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.hideOnLastClosed": false,
  "terminal.integrated.smoothScrolling": true,

  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lock*",
    "*.sqlite": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },

  "files.associations": {
    "*.css": "tailwindcss"
  },
  "files.autoGuessEncoding": true,
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true,
    "**/.ruff_cache": true
  },
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,

  "chat.agent.enabled": true,
  "chat.agent.maxRequests": 100,
  "chat.viewSessions.enabled": false,

  "emmet.excludeLanguages": [ ],

  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.renderSideBySide": true,

  "[css]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[html]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonl]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.tabSize": 2,
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "[mdx]": {
    "editor.tabSize": 2
  },
  "[python]": {
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  "javascript.preferences.importModuleSpecifier": "non-relative",
  "javascript.preferences.quoteStyle": "double",
  "javascript.updateImportsOnFileMove.enabled": "never",
  "json.format.keepLines": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.terminal.activateEnvInCurrentTerminal": false,
  "python.terminal.activateEnvironment": false,
  "typescript.locale": "en",
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.preferences.quoteStyle": "double",
  "typescript.updateImportsOnFileMove.enabled": "never",

  "biome.enabled": false,

  "claudeCode.selectedModel": "opus",
  "claudeCode.preferredLocation": "panel",

  "color-highlight.languages": [ "*", "!python" ],
  "color-highlight.markerType": "dot-before",

  "cSpell.enabledFileTypes": {
    "*": true,
    "log": false,
    "txt": false,
    "drawio": false
  },
  "cSpell.userWords": [
    "appinstalled",
    "arange",
    "argmax",
    "argmin",
    "astro",
    "astype",
    "barh",
    "beforeinstallprompt",
    "boldsymbol",
    "clsx",
    "cmap",
    "colorbar",
    "contentlayer",
    "convolutional",
    "datapack",
    "datasource",
    "DMARC",
    "DOCFILE",
    "donot",
    "drawio",
    "dtype",
    "dvipdfmx",
    "einops",
    "esbenp",
    "esbuild",
    "figsize",
    "fuga",
    "GELU",
    "gtag",
    "headlessui",
    "Hiragino",
    "hoge",
    "imshow",
    "includegraphics",
    "ipynb",
    "kage",
    "katex",
    "keepdim",
    "langchain",
    "latexmk",
    "linecap",
    "linejoin",
    "logit",
    "lualatex",
    "marp",
    "mathbb",
    "mathbf",
    "mathcal",
    "mathjax",
    "mathrm",
    "matplotlib",
    "matsutake",
    "Meiryo",
    "Mersenne",
    "Mincho",
    "miniflare",
    "minmax",
    "mtllib",
    "NAND",
    "ndarray",
    "newmtl",
    "nonstopmode",
    "noopener",
    "noopenner",
    "noreferrer",
    "Noto",
    "numel",
    "optim",
    "pairplot",
    "paralleldrive",
    "platex",
    "Pretrained",
    "Pylance",
    "pyplot",
    "pytest",
    "Qiita",
    "seaborn",
    "sklearn",
    "slidev",
    "softmax",
    "sonner",
    "sortedcontainers",
    "Subtractor",
    "synctex",
    "tailwindcss",
    "Tauri",
    "tiktok",
    "todohighlight",
    "torchvision",
    "tqdm",
    "tsyringe",
    "Turborepo",
    "unsqueeze",
    "upsert",
    "usemtl",
    "VITE",
    "vsintellicode",
    "wada",
    "webm",
    "webp",
    "xlabel",
    "xlim",
    "xmax",
    "xmin",
    "ylabel",
    "ymax",
    "ymin",
    "yticks",
    "Zenn"
  ],

  "database-client.autoSync": true,

  "git.autofetch": "all",
  "git.autorefresh": true,
  "git.autoStash": true,
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "git.replaceTagsWhenPull": true,

  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.chat.agent.thinkingTool": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.editor.temporalContext.enabled": true,
  "github.copilot.chat.edits.temporalContext.enabled": true,

  "githubPullRequests.createOnPublishBranch": "never",
  "githubPullRequests.fileListLayout": "tree",
  "githubPullRequests.pullBranch": "never",

  "hediet.vscode-drawio.resizeImages": null,

  "json.maxItemsComputed": 10000,
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true
  },

  "jupyter.askForKernelRestart": false,
  "jupyter.runStartupCommands": [
    "%load_ext autoreload",
    "%autoreload 2",
    "%matplotlib inline"
  ],

  "liveServer.settings.donotVerifyTags": true,
  "liveServer.settings.donotShowInfoMsg": true,

  "markdown.editor.filePaste.enabled": "always",
  "markdown.editor.filePaste.videoSnippet": "<video controls autoplay loop muted playsinline src=\"${src}\" title=\"${title}\"></video>",
  "markdown.marp.exportType": "html",
  "markdown.marp.html": "all",
  "markdown.marp.pdf.noteAnnotations": false,
  "markdown.marp.pptx.editable": "on",
  "markdown.marp.themes": [
    "https://raw.githubusercontent.com/kage1020/marp-theme/main/kage.css",
    "https://raw.githubusercontent.com/kage1020/marp-theme/main/kage-academic.css",
    "https://raw.githubusercontent.com/kage1020/marp-theme/main/word.css"
  ],

  "markdownlint.config": {
    "MD001": false,
    "MD012": false,
    "MD024": false,
    "MD025": false,
    "MD026": false,
    "MD029": false,
    "MD033": false,
    "MD036": false,
    "MD040": false,
    "MD041": false,
    "MD045": false,
    "MD049": false
  },

  "markdown-preview-enhanced.codeBlockTheme": "github-dark.css",
  "markdown-preview-enhanced.enableExtendedTableSyntax": true,
  "markdown-preview-enhanced.hideDefaultVSCodeMarkdownPreviewButtons": false,
  "markdown-preview-enhanced.previewTheme": "atom-light.css",

  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "notebook.insertFinalNewline": true,
  "notebook.lineNumbers": "on",
  "notebook.output.scrolling": true,
  "notebook.stickyScroll.enabled": true,
  "notebook.variablesView": true,

  "prettier.semi": false,

  "reactColorComponents.clientBackground": "#ffffff00",
  "reactColorComponents.clientForeground": "#ff719b",
  "reactColorComponents.serverBackground": "#ffffff00",
  "reactColorComponents.serverForeground": "#4ec9b0",

  "tailwindCSS.classFunctions": [ "clsx", "cva", "cx", "tv", "tw", "twMerge" ],

  "todohighlight.keywords": [
    {
      "text": "μ",
      "backgroundColor": "#b8950033",
      "color": "#d4d4d4",
      "border": "1px solid #b89500"
    },
    {
      "text": "λ",
      "backgroundColor": "#b8950033",
      "color": "#d4d4d4",
      "border": "1px solid #b89500"
    },
    {
      "text": "ρ",
      "backgroundColor": "#b8950033",
      "color": "#d4d4d4",
      "border": "1px solid #b89500"
    },
    {
      "text": "≥",
      "backgroundColor": "#b8950033",
      "color": "#d4d4d4",
      "border": "1px solid #b89500"
    },
    {
      "text": "≤",
      "backgroundColor": "#b8950033",
      "color": "#d4d4d4",
      "border": "1px solid #b89500"
    },
    {
      "text": "∞",
      "backgroundColor": "#b8950033",
      "color": "#d4d4d4",
      "border": "1px solid #b89500"
    },
    {
      "text": "−",
      "backgroundColor": "#b8950033",
      "color": "#d4d4d4",
      "border": "1px solid #b89500"
    }
  ]
}
